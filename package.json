  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && ./vendor/bin/sail up",
    "stop:backend": "cd backend && ./vendor/bin/sail down",
    "dev:frontend": "vite frontend --port 3000",
    "build": "vite build frontend",
    "migrate": "cd backend && ./vendor/bin/sail artisan migrate",
    "seed": "cd backend && ./vendor/bin/sail artisan db:seed"
  },
